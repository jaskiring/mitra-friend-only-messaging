# Copy this file to .env and fill in real values. Do NOT commit .env.
COMETCHAT_APP_ID=
COMETCHAT_REGION=us
COMETCHAT_REST_API_KEY=
COMETCHAT_AUTH_KEY=

DATABASE_URL=file:./dev.db

PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Basic auth for the CometChat Custom Moderation webhook
MODERATION_WEBHOOK_USER=cometchat
MODERATION_WEBHOOK_PASSWORD=
